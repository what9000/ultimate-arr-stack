# Local .lan domains for port-free service access
# DNS resolves to Traefik's macvlan IP (where port 80 is available)
# Traefik routes by Host header to correct service
#
# Usage (on NAS):
#   sed "s/TRAEFIK_LAN_IP/10.10.0.11/g" pihole/02-local-dns.conf.example > pihole/02-local-dns.conf
#   docker restart pihole
#
# Note: Replace 10.10.0.11 with your chosen TRAEFIK_LAN_IP
# Note: `pihole reloaddns` does NOT pick up bind-mount changes — use `docker restart pihole`

# Media services
address=/jellyfin.lan/TRAEFIK_LAN_IP
address=/plex.lan/TRAEFIK_LAN_IP
address=/seerr.lan/TRAEFIK_LAN_IP
address=/jellyseerr.lan/TRAEFIK_LAN_IP
address=/jellyseer.lan/TRAEFIK_LAN_IP

# *arr stack (VPN-protected)
address=/sonarr.lan/TRAEFIK_LAN_IP
address=/radarr.lan/TRAEFIK_LAN_IP
address=/prowlarr.lan/TRAEFIK_LAN_IP
address=/bazarr.lan/TRAEFIK_LAN_IP

# Download clients
address=/qbit.lan/TRAEFIK_LAN_IP
address=/sabnzbd.lan/TRAEFIK_LAN_IP

# Infrastructure
address=/traefik.lan/TRAEFIK_LAN_IP
address=/pihole.lan/TRAEFIK_LAN_IP

# Utilities
address=/uptime.lan/TRAEFIK_LAN_IP
address=/duc.lan/TRAEFIK_LAN_IP
address=/beszel.lan/TRAEFIK_LAN_IP

# Proper IPv6 response for .lan domains (no real IPv6 addresses needed).
# Returns :: (unspecified) instead of NXDOMAIN for AAAA queries. This is the
# standard dnsmasq approach for IPv4-only local domains. Required because
# Alpine/musl-based containers (e.g. Gluetun) treat AAAA NXDOMAIN as a hard
# failure — even when the A (IPv4) record resolves fine.
address=/lan/::
